{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=NearUDb;Trusted_Connection=True"
  },
  "JwtSettings": {
    "Secret": "YOUR_VERY_SECURE_SECRET_KEY_MINIMUM_64_CHARACTERS_FOR_PRODUCTION_USE_CHANGE_THIS",
    "Issuer": "NearU-Backend-API",
    "Audience": "NearU-Client-App",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://yourdomain.com"
    ]
  }
}
