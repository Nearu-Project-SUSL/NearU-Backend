# ─────────────────────────────────────────────────────────────
# NearU Backend — Environment Variables
#
# Copy this file to /opt/nearu/.env on the Droplet and fill in
# the actual values. This file is .gitignored and must NEVER be
# committed to source control.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (pointing to Dockerised DB on Droplet)
# Example: Host=postgres;Port=5432;Database=nearudb;Username=postgres;Password=yourpassword
POSTGRES_CONNECTION_STRING=Host=<db-container-name>;Port=5432;Database=<db-name>;Username=<user>;Password=<password>

# JWT — use a long, randomly generated secret (min 32 chars)
JWT_SECRET_KEY=<your-super-secret-jwt-key-min-32-characters>

# ImageKit credentials
IMAGEKIT_PUBLIC_KEY=<your-imagekit-public-key>
IMAGEKIT_PRIVATE_KEY=<your-imagekit-private-key>
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your-imagekit-id>
